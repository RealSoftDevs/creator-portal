generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  password       String
  isPremium      Boolean   @default(false)
  razorpayId     String?   @unique
  subscriptionId String?
  createdAt      DateTime  @default(now())
  portal         Portal?
}

model Portal {
  id               String    @id @default(cuid())
  slug             String    @unique
  title            String    @default("My Creator Portal")
  bio              String?   @default("")
  avatar           String?
  templateId       String    @default("template1")
  primaryColor     String    @default("#f5f5f5")
  backgroundType   String    @default("image")
  backgroundImage  String?   @default("images/default-bg.jpg")
  gradientStart    String?   @default("#000000")
  gradientEnd      String?   @default("#ffffff")
  textColor        String?
  fontFamily       String    @default("font-sans")
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id])
  links            Link[]
  products         Product[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Public page settings
  publicTemplateId     String    @default("template1")
  publicPrimaryColor   String    @default("#000000")
  publicBackgroundType String   @default("color")
  publicGradientStart  String?
  publicGradientEnd    String?
  publicBackgroundImage String?
  publicTextColor      String?
  publicFontFamily     String    @default("font-sans")

  // Admin page settings (premium only)
  adminTemplateId      String?   @default("template1")
  adminPrimaryColor    String?   @default("#000000")
  adminBackgroundType  String?   @default("color")
  adminGradientStart   String?
  adminGradientEnd     String?
  adminBackgroundImage String?
  adminTextColor       String?
  adminFontFamily      String?   @default("font-sans")
}

model Link {
  id            String    @id @default(cuid())
  title         String
  url           String
  wrappedUrl    String?
  imageUrl      String?
  iconType      String?
  order         Int       @default(0)
  clicks        Int       @default(0)
  isActive      Boolean   @default(true)
  portalId      String
  portal        Portal    @relation(fields: [portalId], references: [id])
  clicksList    Click[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Click {
  id        String    @id @default(cuid())
  linkId    String
  link      Link      @relation(fields: [linkId], references: [id])
  timestamp DateTime  @default(now())
  userAgent String?
  referrer  String?
  country   String?
  device    String?
}

model Product {
  id        String    @id @default(cuid())
  title     String
  imageUrl  String
  buyLink   String
  price     String?
  platform  String    @default("custom")
  order     Int       @default(0)
  portalId  String
  portal    Portal    @relation(fields: [portalId], references: [id])
  createdAt DateTime  @default(now())
}